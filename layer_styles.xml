<?xml version="1.0" encoding="UTF-8"?>
<LayerStyles>
  <Layer id="cat_polygons">
    <name>猫猫活动范围</name>
    <color>#ff7f50</color>
    <visible>true</visible>
    <minZoom>0</minZoom>
    <maxZoom>20</maxZoom>
    <strokeWeight>3</strokeWeight>
    <fillOpacity>0.35</fillOpacity>
  </Layer>
  <Layer id="cat_labels">
    <name>猫猫名字标签</name>
    <color>#FF7F50</color>
    <visible>true</visible>
    <minZoom>0</minZoom>
    <maxZoom>20</maxZoom>
    <fontSize>12</fontSize>
  </Layer>
  <Layer id="feed_points">
    <name>喂食点</name>
    <color>#5BB5A2</color>
    <visible>true</visible>
    <minZoom>0</minZoom>
    <maxZoom>20</maxZoom>
  </Layer>
  <Layer id="my_location">
    <name>我的位置</name>
    <color>#FF7F50</color>
    <visible>true</visible>
    <minZoom>0</minZoom>
    <maxZoom>20</maxZoom>
  </Layer>
</LayerStyles>